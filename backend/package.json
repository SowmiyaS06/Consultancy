{
  "name": "vel-super-market-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:5001": "set PORT=5001&& node src/server.js",
    "start:auto": "node scripts/run-with-free-port.cjs node src/server.js",
