NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-name>.mongodb.net/myDatabase?retryWrites=true&w=majority&appName=Cluster0
LOCAL_MONGODB_URI=mongodb://localhost:27017/vel-super-market
MIGRATION_MODE=upsert
MONGODB_CONNECT_RETRIES=5
MONGODB_RETRY_DELAY_MS=3000
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=1d
